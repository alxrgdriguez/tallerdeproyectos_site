---
import "../styles/global.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/layout/Footer.astro";
---

<BaseLayout title="404 - Página no encontrada | Taller de Proyectos SL">
  <Fragment slot="header">
    <Navbar />
  </Fragment>

  <main class="relative isolate min-h-[100svh] overflow-hidden bg-slate-950 text-white">
    <!-- Video de fondo -->
    <video
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      class="absolute inset-0 -z-20 h-full w-full object-cover"
      aria-hidden="true"
    >
      <source
        src="https://ik.imagekit.io/proyectostd/videos/video_Plano.mp4?updatedAt=1754215990237"
        type="video/mp4"
      />
    </video>

    <!-- Overlay oscuro -->
    <div class="absolute inset-0 -z-10 bg-slate-950/70"></div>

    <!-- Gradientes decorativos -->
    <div
      class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top,rgba(34,211,238,0.18),transparent_35%),radial-gradient(circle_at_bottom,rgba(37,99,235,0.22),transparent_40%)]"
    ></div>

    <!-- Contenido -->
    <section class="mx-auto flex min-h-[100svh] max-w-7xl items-center px-6 py-24 sm:px-10">
      <div class="max-w-3xl">
        <p
          class="mb-4 inline-flex items-center rounded-full border border-white/15 bg-white/10 px-4 py-1.5 text-sm font-medium tracking-wide text-cyan-200 backdrop-blur"
        >
          Error 404
        </p>

        <h1 class="text-5xl font-black leading-tight tracking-tight sm:text-6xl lg:text-7xl">
          Esta página no
          <span class="bg-gradient-to-r from-cyan-300 to-blue-400 bg-clip-text text-transparent">
            aparece en el plano
          </span>
        </h1>

        <p class="mt-6 max-w-2xl text-base leading-7 text-slate-200 sm:text-lg">
          La dirección que has visitado no existe, ha cambiado o ya no está disponible.
          Pero no te preocupes: puedes volver al inicio en el botón de abajo.
        </p>

        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
          <a
            href="/"
            class="inline-flex items-center justify-center rounded-full bg-gradient-to-r from-blue-700 to-cyan-600 px-8 py-4 text-sm font-semibold text-white shadow-lg shadow-cyan-900/30 transition duration-300 hover:-translate-y-0.5 hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-cyan-300 focus:ring-offset-2 focus:ring-offset-slate-950"
          >
            Volver al inicio
          </a>

        </div>

        <div class="mt-12 border-l border-white/15 pl-4 text-sm text-slate-300">
          <p>
            Consejo: revisa la URL o navega desde el menú principal para encontrar la sección que buscas.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Fragment slot="footer">
    <Footer />
  </Fragment>
</BaseLayout>