<section
  id="contacto"
  class="fade-in-up relative bg-[#f8f9fc] py-20 px-6 md:px-12 lg:px-20"
>
  <!-- Fondo decorativo -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="absolute -top-40 -right-40 h-[600px] w-[600px] rounded-full bg-blue-100/40 blur-3xl"></div>
    <div class="absolute -bottom-40 -left-20 h-[400px] w-[400px] rounded-full bg-cyan-100/30 blur-3xl"></div>
  </div>

  <div class="relative mx-auto max-w-4xl">
    <!-- Cabecera -->
    <div class="mb-14 text-center">
      <h2
        class="text-5xl md:text-6xl font-extrabold text-blue-900 tracking-tight mb-6"
      >
        Estamos aquí para ayudarte
      </h2>

      <p class="mx-auto max-w-2xl text-lg leading-relaxed text-gray-600">
        Cuéntanos tu proyecto y te responderemos
        <strong class="font-semibold text-gray-800">lo antes posible</strong>.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6">
      <!-- Contacto directo -->
      <div class="rounded-3xl border border-gray-100 bg-white p-8 shadow-lg">
        <h3
          class="mb-6 text-sm font-semibold uppercase tracking-widest text-gray-500"
        >
          Contacto directo
        </h3>

        <div class="space-y-4">
          <!-- Dirección -->
          <div
            class="rounded-2xl bg-gray-50 p-5 transition-all duration-300 hover:-translate-y-0.5 hover:bg-blue-50 hover:shadow-md"
          >
            <div class="flex items-start gap-4">
              <div
                class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-xl border border-gray-100 bg-white shadow-sm"
              >
                <svg
                  class="h-5 w-5 text-blue-600"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                  />
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                  />
                </svg>
              </div>

              <div class="min-w-0 flex-1">
                <p
                  class="mb-1 text-xs font-semibold uppercase tracking-wider text-gray-500"
                >
                  Dirección
                </p>
                <address class="text-lg font-semibold">
                  Avenida Andalucía, 16. 1º P5<br />
                  04640 Pulpí, Almería
                </address>

                <div class="mt-4">
                  <a
                    href="https://maps.app.goo.gl/hy2LuTwEUC8HUv1z9"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Abrir dirección en Google Maps"
                    class="inline-flex items-center justify-center rounded-xl bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white ring-1 ring-gray-200 transition hover:bg-blue-700"
                  >
                    Abrir en Google Maps
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Teléfono -->
          <div
            class="rounded-2xl bg-blue-50 p-5 ring-1 ring-blue-100 transition-all duration-300 hover:-translate-y-0.5 hover:bg-blue-100 hover:shadow-md"
          >
            <div class="flex items-start gap-4">
              <div
                class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-xl border border-blue-100 bg-white shadow-sm"
              >
                <svg
                  class="h-5 w-5 text-blue-600"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                  />
                </svg>
              </div>

              <div class="min-w-0 flex-1">
                <p
                  class="mb-1 text-xs font-semibold uppercase tracking-wider text-gray-500"
                >
                  Teléfono
                </p>
                <p class="text-lg font-semibold">
                  +34 950 465 466
                </p>

                <div class="mt-4">
                  <a
                    href="tel:+34950465466"
                    aria-label="Llamar al 950 46 54 66"
                    class="inline-flex items-center justify-center rounded-xl bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-700"
                  >
                    Llamar ahora
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Email -->
          <div
            class="rounded-2xl bg-gray-50 p-5 transition-all duration-300 hover:-translate-y-0.5 hover:bg-blue-50 hover:shadow-md"
          >
            <div class="flex items-start gap-4">
              <div
                class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-xl border border-gray-100 bg-white shadow-sm"
              >
                <svg
                  class="h-5 w-5 text-blue-600"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  />
                </svg>
              </div>

              <div class="min-w-0 flex-1">
                <p
                  class="mb-1 text-xs font-semibold uppercase tracking-wider text-gray-500"
                >
                  Email
                </p>
                <p class="break-all font-semibold">
                  tallerdeproyectospulpi@gmail.com
                </p>

                <div class="mt-4">
                  <a
                    href="mailto:tallerdeproyectospulpi@gmail.com"
                    aria-label="Enviar un correo a tallerdeproyectospulpi@gmail.com"
                    class="inline-flex items-center justify-center rounded-xl bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white ring-1 ring-gray-200 transition hover:bg-blue-700"
                  >
                    Enviar mensaje
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>